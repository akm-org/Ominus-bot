# ============================================================
# Minecraft Automation Bot – Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Alternatively, set these as real environment variables or
# put your server IP in ip.txt and leave HOST empty.
# ============================================================

# ------ Server connection ------
HOST=                        # Server address (or leave blank to read from ip.txt)
PORT=25565                   # Default Minecraft port
VERSION=1.21.4               # Minecraft version string

# ------ Auth / registration ------
PASSWORD=Secure@Bot2025!     # Password used for /register and /login
TP_PLAYER=AKMVyron           # Player who sends the TP request

# ------ Bot behaviour ------
RIGHT_CLICK_PER_SECOND=8     # How fast to right-click the vault
WAIT_AFTER_TP=5              # Seconds to wait after teleport before anything
WAIT_FOR_KEY_DROP=10         # Seconds to stand still so you can drop the Ominous Vault key
ROTATION_SPEED=25            # Degrees per second for smooth rotation
RECONNECT_DELAY=5            # Seconds between cycles
AUTO_LEAVE_SECONDS=100       # Auto-disconnect this many seconds after TPA is accepted

# ------ Parallelism ------
MAX_BOTS=1                   # Number of concurrent bot slots

# ------ Timeouts (seconds) ------
REGISTER_TIMEOUT=30
LOGIN_TIMEOUT=30
TP_WAIT_TIMEOUT=120
VAULT_OPEN_TIMEOUT=30
INVENTORY_SETTLE_DELAY=2
